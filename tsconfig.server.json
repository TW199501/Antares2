{
   "compilerOptions": {
      "target": "ES2021",
      "module": "CommonJS",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "sourceMap": true,
      "noImplicitAny": true,
      "outDir": "dist-server",
      "paths": {
         "common/*": ["./src/common/*"]
      }
   },
   "include": ["src/main/**/*", "src/common/**/*"],
   "exclude": ["node_modules"]
}

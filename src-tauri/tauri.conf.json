{
   "productName": "Antares SQL",
   "version": "0.8.0",
   "identifier": "com.fabio286.antares",
   "build": {
      "beforeDevCommand": "npm run vite:dev",
      "devUrl": "http://localhost:5173",
      "beforeBuildCommand": "npm run vite:build",
      "frontendDist": "../dist"
   },
   "bundle": {
      "active": true,
      "targets": ["nsis"],
      "resources": {
         "../sidecar/node.exe": "sidecar/node.exe",
         "../sidecar/antares-server.cjs": "sidecar/antares-server.cjs",
         "../node_modules/better-sqlite3/**/*": "node_modules/better-sqlite3/",
         "../node_modules/ssh2/**/*": "node_modules/ssh2/",
         "../node_modules/cpu-features/**/*": "node_modules/cpu-features/",
         "../node_modules/@heroku/socksv5/**/*": "node_modules/@heroku/socksv5/",
         "../node_modules/@fabio286/ssh2-promise/**/*": "node_modules/@fabio286/ssh2-promise/",
         "../node_modules/bindings/**/*": "node_modules/bindings/",
         "../node_modules/file-uri-to-path/**/*": "node_modules/file-uri-to-path/"
      },
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"]
   },
   "plugins": {},
   "app": {
      "windows": [{
         "title": "Antares SQL",
         "width": 1024,
         "height": 800,
         "minWidth": 900,
         "minHeight": 550
      }],
      "security": {
         "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
      }
   }
}

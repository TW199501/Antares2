{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sidecar: Node Attach",
      "cwd": "${workspaceFolder}",
      "port": 9230,
      "request": "attach",
      "sourceMaps": true,
      "type": "node",
      "timeout": 1000000
    },
    {
      "name": "Renderer: Vite",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src/renderer"
    }
  ],
  "compounds": [
    {
      "name": "Tauri: Renderer + Sidecar",
      "configurations": ["Sidecar: Node Attach", "Renderer: Vite"]
    }
  ]
}

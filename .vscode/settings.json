{
   "files.eol": "\n",
   "files.insertFinalNewline": true,
   "files.trimTrailingWhitespace": true,
   "[markdown]": {
      "files.trimTrailingWhitespace": false
   },
   "conventionalCommits.scopes": [
      "UI",
      "core",
      "MySQL",
      "PostgreSQL",
      "SQLite",
      "Firebird SQL",
      "Windows",
      "translation",
      "Linux",
      "MacOS",
      "deps",
      "Flatpak"
   ],
   "search.exclude": {
      ".claude/worktrees/**": true
   },
   "files.watcherExclude": {
      ".claude/worktrees/**": true
   },
   "i18n-ally.localesPaths": [
      "src/renderer/i18n"
   ],
   "i18n-ally.sourceLanguage": "en-US",
   "i18n-ally.keystyle": "nested",
   "i18n-ally.enabledParsers": ["json"],
   "i18n-ally.enabledFrameworks": ["vue"],
   "i18n-ally.namespace": false,
   "i18n-ally.pathMatcher": "{locale}.json",
   "i18n-ally-next.localesPaths": [
      "src/renderer/i18n"
   ],
   "i18n-ally-next.sourceLanguage": "en-US",
   "i18n-ally-next.keystyle": "nested",
   "i18n-ally-next.enabledParsers": ["ts", "json"],
   "i18n-ally-next.enabledFrameworks": ["vue"],
   "i18n-ally-next.namespace": false,
   "i18n-ally-next.pathMatcher": "{locale}.ts",
   "i18n-ally-next.extract.autoDetect": true,
   "i18n-ally-next.extract.keygenStrategy": "slug",
   "i18n-ally-next.editor.preferEditor": true,
   "i18n-ally-next.extract.ignored": [
      ""
   ],
   "i18n-ally-next.extract.keyMaxLength": 40
}

{
   "conventionalCommits.scopes": [
      "UI",
      "core",
      "MySQL",
      "PostgreSQL",
      "SQLite",
      "Firebird SQL",
      "Windows",
      "translation",
      "Linux",
      "MacOS",
      "deps",
      "Flatpak"
   ],
   "i18n-ally-next.annotationInPlace": true,
   "i18n-ally-next.annotationInPlaceFullMatch": true,
   "i18n-ally-next.localesPaths": [
      "src/renderer/i18n"
   ],
   "i18n-ally-next.sourceLanguage": "en-US",
   "i18n-ally-next.keystyle": "nested",
   "i18n-ally-next.enabledParsers": ["ts","json"],
   "i18n-ally-next.enabledFrameworks": ["vue"],
   "i18n-ally-next.namespace": false,
   "i18n-ally-next.pathMatcher": "{locale}.ts",
   "i18n-ally-next.extract.autoDetect": true,
   "i18n-ally-next.extract.keygenStrategy": "slug",
   "i18n-ally-next.editor.preferEditor": true,
   "i18n-ally-next.extract.ignored": [
      ""
   ],
   "i18n-ally-next.extract.keyMaxLength": 40
}
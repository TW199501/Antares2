{
  "name": "antares2",
  "productName": "Antares2 SQL",
  "version": "0.8.0",
  "description": "A modern, fast and productivity driven SQL client with a focus in UX.",
  "license": "MIT",
  "repository": "https://github.com/antares-sql/antares.git",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "sidecar:dev": "tsx watch src/main/server.ts --port 5555",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/build-sidecar.mjs && tauri build",
    "lint": "eslint . --ext .js,.ts,.vue && stylelint \"./src/**/*.{css,scss,sass,vue}\"",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix && stylelint \"./src/**/*.{css,scss,sass,vue}\" --fix",
    "verify:tauri-migration": "node ./scripts/checkTauriMigration.js",
    "test:e2e": "npx playwright test",
    "translation:check": "tsx ./scripts/translationCheck.ts",
    "contributors:add": "all-contributors add",
    "contributors:generate": "all-contributors generate",
    "prepare": "husky"
  },
  "author": "Fabio Di Stasio <info@fabiodistasio.it>",
  "dependencies": {
    "@fabio286/ssh2-promise": "^1.0.4-b",
    "@faker-js/faker": "^10.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@jamescoyle/vue-icon": "0.1.2",
    "@mdi/js": "~7.2.96",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@turf/helpers": "^7.3.4",
    "@vue/compiler-sfc": "^3.5.32",
    "@vueuse/core": "^14.2.1",
    "ace-builds": "^1.43.6",
    "better-sqlite3": "^12.9.0",
    "buffer": "^6.0.3",
    "ciaplu": "^2.5.0",
    "cpu-features": "^0.0.10",
    "encoding": "~0.1.13",
    "fastify": "^5.8.4",
    "floating-vue": "^5.2.2",
    "json2php": "~0.0.12",
    "leaflet": "~1.9.4",
    "marked": "~18.0.0",
    "moment": "~2.30.1",
    "mssql": "^12.2.1",
    "mysql2": "~3.22.0",
    "node-firebird": "~1.1.8",
    "pg": "~8.20.0",
    "pg-query-stream": "~4.2.3",
    "pgsql-ast-parser": "~7.2.1",
    "pinia": "^3.0.4",
    "spectre.css": "^0.5.9",
    "sql-formatter": "^15.7.3",
    "sql-highlight": "^6.1.0",
    "v-mask": "^2.3.0",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vuedraggable": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "cpu-features", "ssh2"]
  },
  "devDependencies": {
    "@commitlint/cli": "~19.0.3",
    "@commitlint/config-conventional": "~19.0.3",
    "@playwright/test": "~1.28.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/marked": "^6.0.0",
    "@types/mssql": "^9.1.11",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "~1.11.6",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "all-contributors-cli": "~6.26.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "playwright": "^1.28.1",
    "playwright-core": "^1.59.1",
    "sass": "^1.99.0",
    "standard-version": "^9.5.0",
    "stylelint": "^15.11.0",
    "stylelint-config-recommended": "^13.0.0",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-scss": "~5.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vue-eslint-parser": "^8.3.0"
  }
}
